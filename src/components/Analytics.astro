---
// Analytics layer — wired once in the template, inherited by every site.
// Per-site IDs come from site.config.json -> analytics.{posthog,clarity}.
// No IDs set => nothing loads (safe no-op), so the live site is unaffected
// until you drop real keys in.
const { site } = Astro.props as { site: { id: string; config: any } };
const ph = site.config.analytics?.posthog ?? {};
const clarity = site.config.analytics?.clarity ?? {};
const siteId = site.id;
const propertyName = site.config.name;
---

{ph.key && (
  <script is:inline define:vars={{ phKey: ph.key, phHost: ph.host || 'https://us.i.posthog.com', siteId, propertyName }}>
    !function(t,e){var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.async=!0,p.src=s.api_host+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="init capture register register_once register_for_session unregister unregister_for_session getFeatureFlag getFeatureFlagPayload isFeatureEnabled reloadFeatureFlags updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures on onFeatureFlags onSessionId getSurveys getActiveMatchingSurveys renderSurvey canRenderSurvey getNextSurveyStep identify setPersonProperties group resetGroups setPersonPropertiesForFlags resetPersonPropertiesForFlags setGroupPropertiesForFlags resetGroupPropertiesForFlags reset get_distinct_id getGroups get_session_id get_session_replay_url alias set_config startSessionRecording stopSessionRecording sessionRecordingStarted captureException loadToolbar get_property getSessionProperty createPersonProfile opt_in_capturing opt_out_capturing has_opted_in_capturing has_opted_out_capturing clear_opt_in_out_capturing debug".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,window.posthog||[]);
    posthog.init(phKey, {
      api_host: phHost,
      person_profiles: 'identified_only',
      autocapture: true,
      capture_pageview: true,
      capture_pageleave: true,
      session_recording: { maskAllInputs: true },
    });
    // Portfolio rollup: every event is tagged with which property it came from.
    posthog.register({ site_id: siteId, property_name: propertyName });
  </script>
)}

{clarity.id && (
  <script is:inline define:vars={{ clarityId: clarity.id }}>
    (function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window,document,"clarity","script",clarityId);
  </script>
)}

<!-- Conversion event taxonomy. Fires named events when a tracker is loaded;
     no-op otherwise. Delegated listeners so template markup needs no edits. -->
<script is:inline>
  (function () {
    function track(name, props) {
      if (window.posthog && window.posthog.capture) window.posthog.capture(name, props || {});
      if (window.clarity) window.clarity('event', name);
    }
    window.trackEvent = track;

    document.addEventListener('click', function (e) {
      var a = e.target.closest('a[href^="tel:"]');
      if (a) return track('phone_click', { href: a.getAttribute('href') });
      var m = e.target.closest('a[href^="mailto:"]');
      if (m) return track('email_click', { href: m.getAttribute('href') });
      var fav = e.target.closest('.unit-fav, [data-fav]');
      if (fav) return track('unit_favorited', { unit: fav.getAttribute('data-fav') || null });
      var tab = e.target.closest('.plan-tab');
      if (tab) return track('floor_plan_viewed', { plan: (tab.textContent || '').trim() });
      var tour3d = e.target.closest('a[href*="matterport"], a[href*="my.matterport"], [data-3d-tour]');
      if (tour3d) return track('tour_3d_opened', {});
      var gal = e.target.closest('#gallery [data-photo], #gallery-strip [data-photo], #gallery figure, #gallery .gallery-item');
      if (gal) return track('gallery_opened', {});
    }, true);

    document.addEventListener('submit', function (e) {
      var f = e.target;
      if (!f || f.tagName !== 'FORM') return;
      if (f.id === 'commute-form') return track('commute_estimated', {});
      if (f.matches('[data-cw-form="leasing"]') || f.id === 'tour-wizard') return track('tour_requested', {});
      if (f.matches('[data-cw-form="maintenance"]')) return track('maintenance_request', {});
    }, true);
  })();
</script>
